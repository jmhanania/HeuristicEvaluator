# -----------------------------------------------------------------------
# HeuristicEvaluator — environment configuration
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored. Never commit real keys.
# -----------------------------------------------------------------------

# Required.
# Get a free key at https://aistudio.google.com — no credit card needed.
# Rate limits on the free tier: 15 req/min, 1500 req/day.
GEMINI_API_KEY=

# Optional. Defaults to <project_root>/storage if not set.
# Use an absolute path. All screenshot and DOM snapshot paths in the
# database are resolved against this root. If you move the project,
# update this value — no DB migration needed.
STORAGE_ROOT=

# Optional. Defaults to 3000.
# The bookmarklet generator reads this at generation time and injects
# it into the bookmarklet script so it always POSTs to the right origin.
# Change this if port 3000 is already in use on your machine.
PORT=3000
